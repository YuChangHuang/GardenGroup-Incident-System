# Optional overrides. The app already works out of the box with the values in
# appsettings.json (local MongoDB, email disabled). Copy this to ".env" only if
# you want to change something.

# MongoDB (defaults to the dockerised instance)
# MongoDB__ConnectionString=mongodb://localhost:27018
# MongoDB__DatabaseName=GardenGrup

# Email / password-reset (left blank = email sending is disabled, app still runs).
# To actually send reset emails, fill these with your own SMTP credentials.
# Email__SmtpUsername=
# Email__SmtpPassword=
