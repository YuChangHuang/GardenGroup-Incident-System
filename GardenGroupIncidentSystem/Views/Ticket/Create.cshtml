@model GardenGroupIncidentSystem.Models.Ticket
@using GardenGroupIncidentSystem.Models
@{
    ViewData["Title"] = "Create Ticket";
    var loggedInUser = Context.Session.GetObject<Employee>("LoggedInUser");

    if (loggedInUser?.EmployeeRole == Role.regular)
    {
        Layout = "~/Views/Dashboard/_DashboardLayout.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/tickets.css" />
}

<div class="container-box">
    <h1>🎫 Create New Ticket</h1>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (loggedInUser == null)
    {
        <div class="alert alert-danger">You must be logged in to create a ticket.</div>
    }
    else
    {
        <p class="info-note">All tickets start as <strong>Open</strong> and deadline is 7 days.</p>

        <form asp-action="Create" asp-controller="Ticket" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="EmployeeID" value="@loggedInUser.Id" />
            <input type="hidden" asp-for="TicketStatus" value="Open" />
            <input type="hidden" asp-for="DateTimeReport" value="@DateTime.Now" />
            <input type="hidden" asp-for="Deadline" value="@DateTime.Now.AddDays(7)" />

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Subject">Subject *</label>
                    <input asp-for="Subject" required />
                </div>

                <div class="form-group">
                    <label asp-for="Type">Type <span style="color: red">*</span></label>
                    <select asp-for="Type" required>
                        <option value="">Select</option>
                        <option>Incident</option>
                        <option>Hardware Request</option>
                        <option>Access Request</option>
                        <option>Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Priority">Priority <span style="color: red">*</span></label>
                    <select asp-for="Priority" required>
                        <option value="">Select</option>
                        <option>High</option>
                        <option>Medium</option>
                        <option>Low</option>
                    </select>
                </div>

                <div class="form-group" style="grid-column: span 2;">
                    <label asp-for="Description">Description <span style="color: red">*</span></label>
                    <textarea asp-for="Description" rows="4" required></textarea>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Submit Ticket</button>
            @if (loggedInUser.EmployeeRole == Role.regular)
            {
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-1">← Cancel</a>
            }
            else
            {
                <a asp-controller="Ticket" asp-action="Index" class="btn btn-secondary">← Cancel</a>
            }

        </form>
    }
</div>
