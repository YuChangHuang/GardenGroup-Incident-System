﻿
@model GardenGroupIncidentSystem.Models.LoginModel
@{
    ViewData["Title"] = "Employee Login";
    Layout = "";
}

<!DOCTYPE html>
<html>
<head>
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Site styles -->
    <link rel="stylesheet" href="~/css/loginindex.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GardenGroupIncidentSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="login-container">
        <div class="header">
            <h1>🔐 Garden Group Login</h1>
        </div>

        <div class="form">
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="error-message">@ViewBag.ErrorMessage</div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="error-message">@TempData["ErrorMessage"]</div>
            }

            <form asp-action="Login" asp-controller="Login" method="post">
                <div class="form-group">
                    <label for="UserName">First Name</label>
                    <input asp-for="UserName" type="text" placeholder="Enter your first name" required />
                </div>

                <div class="form-group">
                    <label for="Password">Password</label>
                    <input asp-for="Password" type="password" placeholder="Enter your password" required />
                </div>

                <button type="submit" class="btn">Login</button>
            </form>
            <div style="margin-top: 20px; text-align: center;">
                <a asp-action="ForgotPassword" asp-controller="PasswordReset" style="color: #667eea; text-decoration: none; font-size: 14px;">Forgot Password?</a>
            </div>
        </div>

        <div class="footer">
            <p>© 2025 Garden Group | Secure Employee Portal</p>
        </div>
    </div>
</body>
</html>