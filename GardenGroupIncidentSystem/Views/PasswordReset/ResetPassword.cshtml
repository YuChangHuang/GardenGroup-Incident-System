@model GardenGroupIncidentSystem.Models.ResetPasswordModel
@* Reset Password page by YuChangHuang *@
@{
    ViewData["Title"] = "Reset Password";
    Layout = "";
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/passwordreset.css" />
</head>
<body>
    <div class="login-container">
        <div class="header">
            <h1>🔐 Reset Password</h1>
        </div>
        <div class="form">
            @* ERROR MESSAGE *@
            @if (TempData["Error"] != null)
            {
                <div class="error-message">@TempData["Error"]</div>
            }

            <p class="info-text">
                Please enter your new password below.
            </p>

            <form asp-action="ResetPassword" asp-controller="PasswordReset" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />
                
                <div class="form-group">
                    <label asp-for="NewPassword">New Password</label>
                    <input asp-for="NewPassword" type="password" placeholder="Enter new password" required />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm new password" required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn">Reset Password</button>
            </form>

            <a asp-action="Index" asp-controller="Login" class="btn-link">Back to Login</a>
        </div>
        <div class="footer">
            <p>© 2025 Garden Group | Secure Employee Portal</p>
        </div>
    </div>
</body>
</html>

