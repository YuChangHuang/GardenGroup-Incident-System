@model GardenGroupIncidentSystem.Models.ForgotPasswordModel
@* Forget Password page implemented by YuChangHuang *@
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "";
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/passwordreset.css" />
</head>
<body>
    <div class="login-container">
        <div class="header">
            <h1>🔑 Forgot Password</h1>
        </div>
        <div class="form">
            @* SUCCESS MESSAGE *@
            @if (TempData["Success"] != null)
            {
                <div class="success-message">@TempData["Success"]</div>
            }

            @* ERROR MESSAGE *@
            @if (TempData["Error"] != null)
            {
                <div class="error-message">@TempData["Error"]</div>
            }

            <p class="info-text">
                Enter your email address and we'll send you a link to reset your password.
            </p>

            <form asp-action="ForgotPassword" asp-controller="PasswordReset" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label asp-for="Email">Email Address</label>
                    <input asp-for="Email" type="email" placeholder="Enter your email address" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <button type="submit" class="btn">Send Reset Link</button>
            </form>

            <a asp-action="Index" asp-controller="Login" class="btn-link">Back to Login</a>
        </div>
        <div class="footer">
            <p>© 2025 Garden Group | Secure Employee Portal</p>
        </div>
    </div>
</body>
</html>

