@{
    ViewData["Title"] = "Archive Management";
    var stats = ViewBag.Statistics as Dictionary<string, object>;
    var archivableCount = ViewBag.ArchivableCount as long?;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .container {
        max-width: 1500px;
        margin: 0 auto;
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        overflow: hidden;
    }

    .header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 36px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .header h1 {
            font-size: 30px;
            font-weight: 600;
        }

    .stats {
        display: flex;
        gap: 16px;
    }

    .stat-card {
        background: rgba(255,255,255,0.2);
        padding: 12px 18px;
        border-radius: 10px;
        text-align: center;
        min-width: 80px;
    }

    .stat-number {
        font-size: 22px;
        font-weight: 700;
    }

    .stat-label {
        font-size: 12px;
        opacity: 0.95;
    }

    .content {
        padding: 30px 40px;
    }

    .alert {
        padding: 14px 18px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 2px solid #c3e6cb;
    }

    .alert-error {
        background: #f8d7da;
        color: #721c24;
        border: 2px solid #f5c6cb;
    }

    .alert-info {
        background: #d1ecf1;
        color: #0c5460;
        border: 2px solid #bee5eb;
    }

    .card {
        background: white;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
    }

    .card-header {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 16px;
        color: #495057;
    }

    .card-warning {
        border-color: #ffc107;
        background: #fff8e1;
    }

    .btn {
        padding: 12px 22px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all .2s;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102,126,234,.4);
        }

    .btn-secondary {
        background: #6c757d;
        color: white;
    }

        .btn-secondary:hover {
            background: #5a6268;
        }

    .btn-warning {
        background: #ffc107;
        color: #212529;
        padding: 14px 24px;
        font-size: 16px;
    }

        .btn-warning:hover {
            background: #e0a800;
        }

    .btn-outline {
        background: white;
        border: 2px solid #667eea;
        color: #667eea;
    }

        .btn-outline:hover {
            background: #667eea;
            color: white;
        }

    .input-date {
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 14px;
        width: 100%;
        max-width: 300px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #495057;
    }

    .muted {
        color: #6c757d;
        font-size: 13px;
    }

    .info-box {
        background: #f8f9fa;
        border-left: 4px solid #667eea;
        padding: 16px;
        border-radius: 4px;
        margin-bottom: 16px;
    }

        .info-box p {
            margin: 4px 0;
        }

    .grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-top: 20px;
    }

    @@media (max-width: 768px) {
        .grid-2 {
            grid-template-columns: 1fr;
        }

        .header {
            flex-direction: column;
            gap: 20px;
        }

        .stats {
            flex-wrap: wrap;
        }
    }
</style>

<div class="container">
    <div class="header">
        <div>
            <h1>🗄️ Ticket Archive Management</h1>
            <p style="margin-top:8px;opacity:.95;">Manage and archive old tickets to optimize database performance</p>
        </div>
        <div class="stats">
            <div class="stat-card">
                <div class="stat-number">@stats["ActiveTicketsCount"]</div>
                <div class="stat-label">Active</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">@stats["ArchivedTicketsCount"]</div>
                <div class="stat-label">Archived</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">@archivableCount</div>
                <div class="stat-label">Ready</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">@stats["ArchivePercentage"]%</div>
                <div class="stat-label">Archive %</div>
            </div>
        </div>
    </div>

    <div class="content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">✅ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">❌ @TempData["Error"]</div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info">ℹ️ @TempData["Info"]</div>
        }

        <!-- MAIN ARCHIVE CARD -->
        <div class="card card-warning">
            <div class="card-header">⚡ Quick Archive - One Click Solution</div>
            <p style="margin-bottom:16px;">
                Archive all closed/resolved tickets older than 2 years to a separate database collection.
            </p>

            @if (archivableCount > 0)
            {
                <div class="info-box">
                    <strong>📦 @archivableCount ticket(s)</strong> ready to be archived.
                </div>
            }

            <form id="archiveForm" method="post" asp-action="ArchiveOldTickets" asp-controller="Archive">
                @Html.AntiForgeryToken()
                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                    <button type="submit" class="btn btn-warning" id="archiveBtn">
                        🗄️ Archive Old Tickets (2+ Years)
                    </button>
                    <a asp-action="Preview" class="btn btn-outline">
                        👁️ Preview First
                    </a>
                </div>
            </form>
        </div>

        <!-- CUSTOM ARCHIVE -->
        <div class="card">
            <div class="card-header">📅 Archive by Custom Date</div>
            <p style="margin-bottom:16px;">Select a date to archive all closed/resolved tickets before that date:</p>

            <form method="post" asp-action="ArchiveByDate" asp-controller="Archive">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="cutoffDate">Archive tickets before:</label>
                    <input type="date"
                           class="input-date"
                           id="cutoffDate"
                           name="cutoffDate"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")"
                           value="@DateTime.Now.AddYears(-2).ToString("yyyy-MM-dd")"
                           required />
                    <div class="muted">Only closed/resolved tickets will be archived</div>
                </div>
                <button type="submit" class="btn btn-primary">
                    🗄️ Archive Tickets
                </button>
            </form>
        </div>

        <!-- ACTIONS GRID -->
        <div class="grid-2">
            <div class="card">
                <div class="card-header">📂 View Archived Tickets</div>
                <p style="margin-bottom:16px;">Browse, search, and restore archived tickets</p>
                <a asp-action="ViewArchived" class="btn btn-secondary">
                    🔍 View Archived Tickets
                </a>
            </div>
            <div class="card">
                <div class="card-header">📊 Archive Statistics</div>
                <p style="margin-bottom:16px;">View detailed archiving statistics and trends</p>
                <a asp-action="Statistics" class="btn btn-primary">
                    📈 View Statistics
                </a>
            </div>
        </div>

        <!-- SYSTEM INFO -->
        <div class="card">
            <div class="card-header">ℹ️ System Information</div>
            <div class="info-box">
                <p><strong>Oldest Active Ticket:</strong> @stats["OldestActiveTicketDate"]</p>
                <p><strong>Newest Archived Ticket:</strong> @stats["NewestArchivedTicketDate"]</p>
                <p><strong>Total Tickets in System:</strong> @stats["TotalTickets"]</p>
            </div>
        </div>

        <!-- BACK BUTTON -->
        <div style="margin-top:20px;">
            <a href="@Url.Action("Index", "Ticket")" class="btn btn-secondary">
                ← Back to Tickets
            </a>
        </div>
    </div>
</div>

<script>
    // Confirmation dialog for archiving
    var form = document.getElementById('archiveForm');
    if (form) {
        form.addEventListener('submit', function(e) {
            if (!confirm('⚠️ Are you sure you want to archive old tickets?\n\nThis will move them to a separate archive database.\n\nThis action can be undone by restoring tickets individually.')) {
                e.preventDefault();
            } else {
                // Disable button and show loading state
                var btn = document.getElementById('archiveBtn');
                btn.disabled = true;
                btn.innerHTML = '⏳ Archiving... Please wait...';
            }
        });
    }
</script>
