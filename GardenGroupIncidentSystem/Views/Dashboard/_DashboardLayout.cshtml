@{
    var loggedInUser = Context.Session.GetObject<Employee>("LoggedInUser");
    var title = ViewData["Title"] as string ?? "Dashboard";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - Garden Group</title>

    @RenderSection("Styles", required: false)



    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Site styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GardenGroupIncidentSystem.styles.css" asp-append-version="true" />

    @section Styles {
        <link rel="stylesheet" href="~/css/dashboardLayout.css" />
    }
</head>

<body>

    <header class="gg-navbar shadow-sm sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand" asp-area="" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-flower1"></i>
                    <span class="d-none d-sm-inline">Garden Group</span>
                </a>
                <a class="navbar-brand" asp-area="" asp-controller="Dashboard" asp-action="Index">
                    <span class="d-none d-sm-inline">Employee Dashboard</span>
                </a>


                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="ms-auto d-flex align-items-center">
                    @if (loggedInUser != null)
                    {
                        <div class="dropdown user-dropdown">
                            <button class="btn btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>
                                <span class="d-none d-md-inline">@loggedInUser.EmployeeRole:</span>
                                @loggedInUser.Name.FirstName
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li>
                                    <h6 class="dropdown-header">
                                        <i class="bi bi-person-badge me-2"></i>@loggedInUser.Name.FirstName @loggedInUser.Name.LastName
                                    </h6>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Login" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-light rounded-pill" asp-controller="Login" asp-action="Index">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Login
                        </a>
                    }
                </div>
            </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-3 px-lg-4 py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top py-4 mt-5">
        <div class="container-fluid px-3 px-lg-4">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-2 mb-md-0">
                    <span class="text-muted small">
                        &copy; @DateTime.Now.Year Garden Group Incident System. All rights reserved.
                    </span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a class="text-muted text-decoration-none small me-3" asp-area="" asp-controller="Home" asp-action="Privacy">
                        <i class="bi bi-shield-check me-1"></i>Privacy
                    </a>
                    <span class="text-muted small">v1.0.0</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Enhanced theme toggle with icon switching
        (function () {
            const savedTheme = localStorage.getItem('gg-theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
            updateThemeIcon(savedTheme);

            const btn = document.getElementById('themeToggle');
            if (!btn) return;

            btn.addEventListener('click', function () {
                const current = document.documentElement.getAttribute('data-bs-theme') || 'light';
                const next = current === 'light' ? 'dark' : 'light';
                document.documentElement.setAttribute('data-bs-theme', next);
                localStorage.setItem('gg-theme', next);
                updateThemeIcon(next);
            });

            function updateThemeIcon(theme) {
                const icon = document.getElementById('themeIcon');
                if (icon) {
                    icon.className = theme === 'light' ? 'bi bi-moon-stars' : 'bi bi-sun-fill';
                }
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>