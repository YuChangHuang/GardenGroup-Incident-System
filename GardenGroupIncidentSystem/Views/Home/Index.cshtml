@{
    ViewData["Title"] = "Home";
}

<div class="hero p-4 p-md-5 shadow-sm mb-5">
    <div class="row align-items-center g-4 hero-content">
        <div class="col-lg-7">
            <div class="mb-3">
                <span class="badge bg-white text-dark px-3 py-2 fw-semibold" style="font-size: 0.875rem;">
                    <i class="bi bi-stars me-1"></i> Incident Management System
                </span>
            </div>
            <h1 class="display-4 fw-bold mb-3" style="line-height: 1.2;">Garden Group Incident System</h1>
            <p class="lead mb-4 opacity-90" style="font-size: 1.125rem;">
                Streamline your operations with powerful ticket tracking, employee management,
                and comprehensive reporting tools. 🌿
            </p>
            <div class="d-flex gap-3 flex-wrap">
                <a class="btn btn-lg btn-light shadow-sm fw-semibold" asp-controller="Employee" asp-action="Index" style="border-radius: 0.75rem;">
                    <i class="bi bi-people me-2"></i>Manage Employees
                </a>
                <a class="btn btn-lg btn-outline-light fw-semibold" asp-controller="Ticket" asp-action="Index" style="border-radius: 0.75rem; border-width: 2px;">
                    <i class="bi bi-ticket-detailed me-2"></i>View Tickets
                </a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card border-0 shadow-lg" style="border-radius: 1.25rem;">
                <div class="card-body p-4">
                    <h6 class="text-muted mb-4 text-center fw-semibold text-uppercase" style="letter-spacing: 0.05em; font-size: 0.75rem;">System Overview</h6>
                    <div class="row g-3">
                        <div class="col-4">
                            <div class="stat-chip">
                                <i class="bi bi-people"></i>
                                <div class="text-center">
                                    <div class="h4 mb-0">109</div>
                                    <small>Total</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="stat-chip">
                                <i class="bi bi-person-badge"></i>
                                <div class="text-center">
                                    <div class="h4 mb-0">80</div>
                                    <small>Regular</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="stat-chip">
                                <i class="bi bi-headset"></i>
                                <div class="text-center">
                                    <div class="h4 mb-0">4</div>
                                    <small>Service</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mb-4">
    <h2 class="h3 fw-bold section-header">
        <i class="bi bi-grid-3x3-gap me-2 text-gradient"></i>Quick Access
    </h2>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card feature-card shadow-sm">
            <div class="card-body p-4">
                <div class="feature-icon">
                    <i class="bi bi-people"></i>
                </div>
                <h5 class="card-title fw-bold mb-2" style="color: var(--gg-dark);">Employee Management</h5>
                <p class="text-muted mb-4" style="font-size: 0.9375rem; line-height: 1.6;">
                    Create, search, and manage employees with role-based access control and detailed profiles.
                </p>
                <a class="btn btn-gg w-100" asp-controller="Employee" asp-action="Index">
                    Open <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card feature-card shadow-sm">
            <div class="card-body p-4">
                <div class="feature-icon">
                    <i class="bi bi-ticket-detailed"></i>
                </div>
                <h5 class="card-title fw-bold mb-2" style="color: var(--gg-dark);">Ticket Management</h5>
                <p class="text-muted mb-4" style="font-size: 0.9375rem; line-height: 1.6;">
                    Track incidents with clear status indicators, priority levels, and detailed activity timelines.
                </p>
                <a class="btn btn-gg w-100" asp-controller="Ticket" asp-action="Index">
                    Open <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card feature-card shadow-sm">
            <div class="card-body p-4">
                <div class="feature-icon">
                    <i class="bi bi-archive"></i>
                </div>
                <h5 class="card-title fw-bold mb-2" style="color: var(--gg-dark);">Archive System</h5>
                <p class="text-muted mb-4" style="font-size: 0.9375rem; line-height: 1.6;">
                    Browse historical tickets with advanced filters, search capabilities, and export tools.
                </p>
                <a class="btn btn-gg w-100" asp-controller="Archive" asp-action="Index">
                    Open <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card info-card border-0">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-lightbulb-fill me-2" style="color: #f59e0b;"></i>Quick Tips
                </h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-3 d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                        <span>Use the search bar to quickly find employees or tickets</span>
                    </li>
                    <li class="mb-3 d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                        <span>Toggle dark mode for comfortable viewing experience</span>
                    </li>
                    <li class="d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                        <span>Check the archive for historical data and reports</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card info-card border-0">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-info-circle-fill me-2" style="color: #06b6d4;"></i>System Status
                </h5>
                <div class="d-flex align-items-center justify-content-between mb-3 pb-3 border-bottom">
                    <span class="text-muted fw-medium">Database Connection</span>
                    <span class="badge bg-success px-3 py-2">
                        <i class="bi bi-check-circle me-1"></i>Active
                    </span>
                </div>
                <div class="d-flex align-items-center justify-content-between mb-3 pb-3 border-bottom">
                    <span class="text-muted fw-medium">Last Backup</span>
                    <span class="badge bg-info px-3 py-2">
                        <i class="bi bi-clock-history me-1"></i>Today
                    </span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <span class="text-muted fw-medium">System Version</span>
                    <span class="badge bg-secondary px-3 py-2">
                        <i class="bi bi-code-square me-1"></i>v1.0.0
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>